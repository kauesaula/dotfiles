{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "network", "bluetooth", "battery", "tray"],
    
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate"
    },
    "clock": {
        "format": "{:%H:%M - %d/%m}",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "VOL {volume}%",
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "WIFI {essid}",
        "format-disconnected": "NO INTERNET"
    },
    "bluetooth": {
        "format": "BT {status}"
    },
    "battery": {
        "format": "BAT {capacity}%"
    },
    "tray": {
        "spacing": 10
    }
}
